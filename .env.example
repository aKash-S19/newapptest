# Copy this file to .env and fill in your values.
# The setup.sh script does this automatically.
# Get these from: https://supabase.com/dashboard → your project → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Optional TURN credentials for reliable WebRTC calls on strict NAT/carrier networks.
# Comma-separated URLs are supported.
EXPO_PUBLIC_TURN_URLS=turn:YOUR_TURN_HOST:3478?transport=udp,turns:YOUR_TURN_HOST:5349?transport=tcp
EXPO_PUBLIC_TURN_USERNAME=YOUR_TURN_USERNAME
EXPO_PUBLIC_TURN_CREDENTIAL=YOUR_TURN_CREDENTIAL
